# --- Python 通用忽略 ---
__pycache__/
*.py[cod]
*$py.class
.env
venv/
env/
.venv/

# --- IDE 配置文件 (可选) ---
.vscode/
.idea/
*.swp

# --- 操作系统文件 ---
.DS_Store
Thumbs.db

# --- 项目特定忽略 (关键部分) ---
# 1. 忽略视频文件 (体积过大，且涉及隐私或版权)
*.mp4
*.MP4
*.avi
*.mov

# 2. 忽略数据库文件 (这是运行时生成的动态数据)
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite

# 3. 忽略模型文件 (如果使用标准模型，建议忽略；如果是自己训练的，且小于100M可保留)
model/*.pt
model/*.onnx
model/*.hef

# 4. 忽略其他可能的输出
*.log
output/
tests/

# 忽略整个集中式构建目录
build/

# 防止有人意外在根目录执行 cmake . 产生的污染文件
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
compile_commands.json

# 忽略所有平台下可能散落的编译动态库和对象文件
*.so
*.o
*.a
*.dylib
*.dll
