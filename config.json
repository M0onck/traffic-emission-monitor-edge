{
  "system": {
    "run_mode": "collection",
    "video_path": "libcamerasrc ! video/x-raw, format=NV12, width=1280, height=720, framerate=30/1 ! videoconvert ! video/x-raw, format=BGR ! appsink name=preview_sink emit-signals=true max-buffers=2 drop=true sync=false",
    "local_video_path": "data/test_videos/input_video.MP4",
    "db_path": "data/database/recorded_data.db",
    "fps": 30,
    "debug_mode": true,
    "use_camera": true
  },
  "lib_paths": {
    "libweather_path": "build/lib/libweather_driver.so",
    "libthermal_path": "build/lib/libmlx90640_driver.so"
  },
  "record_options": {
    "enable_record": true,
    "segment_length_min": 5,
    "save_path": "data/recorded_videos"
  },
  "display": {
    "frame_width": 1280,
    "frame_height": 720
  },
  "edge_models": {
    "hef_path": "resources/yolov8m.hef",
    "y5fu_path": "perception/plate_classifier/models/y5fu_320x_sim.onnx",
    "litemodel_path": "perception/plate_classifier/models/litemodel_cls_96x_r1.onnx"
  },
  "switches": {
    "enable_motion": true,
    "enable_ocr": true
  },
  "kinematics": {
    "speed_window_sec": 2.2,
    "accel_window_sec": 3.0,
    "border_margin": 20,
    "min_tracking_sec": 0.3,
    "max_physical_accel": 6.0,
    "exit_timeout_sec": 1.0
  },
  "ocr_params": {
    "retry_cooldown": 5,
    "confidence_threshold": 0.4
  },
  "yolo_classes": {
    "yolo_class_car": 2,
    "yolo_class_bus": 5,
    "yolo_class_truck": 7
  },
  "physics_params": {
    "road_grade_percent": 0.0
  },
  "quality_control": {
    "min_valid_trajectory_points": 15,
    "min_survival_sec": 1.0,
    "min_moving_distance_m": 2.0,
    "blur_threshold": 100.0
  },
  "time_windows": {
    "alignment_delay_sec": 60.0,
    "integration_window_sec": 300.0,
    "baseline_window_minute": 10.0,
    "db_align_interval_sec": 60.0
  },
  "physics_priors": {
    "weather_station_x_pos": 0.0,
    "road_direction_angle": 0.0,
    "nev_mass_penalty_ratio": 1.2
  }
}