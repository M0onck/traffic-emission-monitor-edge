{
  "system": {
    "video_path": "video/input_video.MP4",
    "target_video_path": "video/output_video.MP4",
    "db_path": "data/traffic_data.db",
    "fps": 30,
    "debug_mode": true
  },
  "edge_models": {
    "hef_path": "resources/yolov8m.hef",
    "post_so_path": "/usr/lib/aarch64-linux-gnu/hailo/tappas/post_processes/libyolo_hailortpp_post.so",
    "y5fu_path": "perception/plate_classifier/models/y5fu_320x_sim.onnx",
    "litemodel_path": "perception/plate_classifier/models/litemodel_cls_96x_r1.onnx"
  },
  "switches": {
    "enable_motion": true,
    "enable_ocr": true
  },
  "kinematics": {
    "speed_window_sec": 2.2, 
    "accel_window_sec": 3.0,
    "border_margin": 20,
    "min_tracking_sec": 0.3,
    "max_physical_accel": 6.0,
    "min_survival_sec": 1.0, 
    "exit_timeout_sec": 1.0  
  },
  "ocr_params": {
    "min_plate_area": 3000,
    "retry_cooldown": 5,
    "run_interval": 5,
    "confidence_threshold": 0.4
  },
  "yolo_classes": {
    "yolo_class_car": 2,
    "yolo_class_bus": 5,
    "yolo_class_truck": 7
  },
  "physics_params": {
    "mass_factor_ev": 1.25,
    "road_grade_percent": 0.0
  },
  "vsp_coefficients": {
    "car":   {"a_m": 0.1564, "b_m": 0.0020, "c_m": 0.00049},
    "bus":   {"a_m": 0.1000, "b_m": 0.0000, "c_m": 0.00030},
    "truck": {"a_m": 0.0920, "b_m": 0.0000, "c_m": 0.00021},
    "default": {"a_m": 0.1564, "b_m": 0.0020, "c_m": 0.00049}
  },
  "type_map": {
    "car,Blue": "Car-gasoline",
    "bus,Blue": "Bus-gasoline",
    "truck,Blue": "Truck-gasoline",
    "car,Yellow": "Car-diesel",
    "bus,Yellow": "Bus-diesel",
    "truck,Yellow": "Truck-diesel",
    "car,Green": "Car-electric",
    "bus,Green": "Bus-electric",
    "truck,Green": "Truck-electric",
    "Default_Car": "LDV-gasoline",
    "Default_Heavy": "HDV-diesel"
  },
  "quality_control": {
    "min_valid_trajectory_points": 15,
    "min_survival_frames": 30,
    "min_moving_distance_m": 2.0
  }
}
